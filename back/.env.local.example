# Copie este arquivo para .env.local e configure com seus valores

# Database (Local Development)
DATABASE_URL=postgresql://postgres:password@localhost:5432/transportepro
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=5

# JWT (Gere uma chave aleatória para desenvolvimento)
JWT_SECRET=dev_secret_key_change_in_production_12345
JWT_EXPIRATION=24h

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=simple

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
